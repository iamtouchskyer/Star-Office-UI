{
  "version": 2,
  "public": true,
  "functions": {
    "api/state.py": {
      "runtime": "python3.9"
    },
    "api/agents.py": {
      "runtime": "python3.9"
    },
    "api/yesterday_memo.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/status",
      "dest": "/api/state"
    },
    {
      "src": "/agents", 
      "dest": "/api/agents"
    },
    {
      "src": "/yesterday-memo",
      "dest": "/api/yesterday_memo"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|webp|gif|ico|svg|woff2|ttf|otf|js|css))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
