{
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/main.py"
    },
    {
      "src": "/state",
      "dest": "/api/main.py"
    },
    {
      "src": "/agents",
      "dest": "/api/main.py"
    },
    {
      "src": "/memo",
      "dest": "/api/main.py"
    },
    {
      "src": "/yesterday-memo",
      "dest": "/api/main.py"
    },
    {
      "src": "/set_state",
      "dest": "/api/main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}