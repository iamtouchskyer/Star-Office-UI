{
  "functions": {
    "api/state.py": {
      "runtime": "python3.9"
    },
    "api/agents.py": {
      "runtime": "python3.9"
    },
    "api/yesterday_memo.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/status",
      "destination": "/api/state"
    },
    {
      "source": "/agents", 
      "destination": "/api/agents"
    },
    {
      "source": "/yesterday-memo",
      "destination": "/api/yesterday_memo"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(png|jpg|jpeg|webp|gif|ico|svg|woff2|ttf|otf|js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ]
}
