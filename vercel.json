{
  "functions": {
    "api/agents.py": {
      "runtime": "python3.9"
    },
    "api/agent-push.py": {
      "runtime": "python3.9"
    },
    "api/heartbeat.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}