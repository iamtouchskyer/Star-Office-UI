{
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|webp|woff2|ttf|ico))$",
      "destination": "/frontend/$1"
    }
  ]
}
