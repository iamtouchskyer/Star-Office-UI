{
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/health",
      "dest": "/api"
    },
    {
      "src": "/state", 
      "dest": "/api"
    },
    {
      "src": "/agents",
      "dest": "/api"
    },
    {
      "src": "/memo",
      "dest": "/api"
    },
    {
      "src": "/yesterday-memo",
      "dest": "/api"
    },
    {
      "src": "/set_state",
      "dest": "/api"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}