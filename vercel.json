{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "functions": {
    "api/state.py": {
      "runtime": "python3.9"
    },
    "api/agents.py": {
      "runtime": "python3.9"
    },
    "api/yesterday_memo.py": {
      "runtime": "python3.9"
    }
  },
  "headers": [
    {
      "source": "/(.*\\.(png|jpg|jpeg|webp|gif|ico|svg|woff2|ttf|otf|js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/status",
      "dest": "/api/state"
    },
    {
      "src": "/agents", 
      "dest": "/api/agents"
    },
    {
      "src": "/yesterday-memo",
      "dest": "/api/yesterday_memo"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
