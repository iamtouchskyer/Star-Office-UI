{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/status",
      "destination": "/api/state"
    },
    {
      "source": "/agents", 
      "destination": "/api/agents"
    },
    {
      "source": "/yesterday-memo",
      "destination": "/api/yesterday_memo"
    }
  ]
}
